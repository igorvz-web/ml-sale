  'Champions':{ic:'🏆',col:'#10b981',
    desc:'Купили недавно, часто, много',
    scores:'R=5 F=5 M=5',
    full:'Лучшие клиенты базы. Высокая выручка, частые и свежие покупки. Ядро бизнеса.',
    action:'Программа лояльности, эксклюзивные предложения, благодарность. Не беспокоить лишний раз — ценят внимание, но не назойливость.'},
  'Loyal':{ic:'💙',col:'#4f8ef7',
    desc:'Покупают регулярно',
    scores:'R≥3 F≥3 M≥4',
    full:'Стабильные клиенты с хорошей выручкой. Надёжная основа — не топ, но предсказуемы.',
    action:'Upsell: предложите новинки и комплектующие. Вовлекайте в реферальные программы.'},
  'Pot. Loyalist':{ic:'⭐',col:'#22d3ee',
    desc:'Новые с хорошим потенциалом',
    scores:'R=4 F≤2 M≥2',
    full:'Покупали недавно, но пока нечасто. Хороший старт — важно развить отношения.',
    action:'Welcome-звонок, обучение продукту, скидка на второй заказ. Цель — сделать Loyal.'},
  'New Customer':{ic:'🌱',col:'#a3e635',
    desc:'Первая недавняя покупка',
    scores:'R=4-5 F=1',
    full:'Только начали сотрудничество. Первый опыт критически важен для удержания.',
    action:'Быстрый follow-up 24–48ч, убедитесь в удовлетворённости, предложите сопутствующий товар.'},
  'At Risk':{ic:'⚠️',col:'#f43f5e',
    desc:'Ранее активные, сейчас пропали',
    scores:'R≤2 F≥3 M≥3',
    full:'Когда-то хорошие клиенты, но давно не покупают. Срочная реактивация.',
    action:'Личный звонок менеджера с конкретным предложением. Выясните причину паузы.'},
  'Cant Lose':{ic:'🆘',col:'#fb7185',
    desc:'Ценные клиенты, но исчезли',
    scores:'R≤2 F≥4 M≥4',
    full:'Приносили много денег, но фактически ушли. Максимальный приоритет.',
    action:'Звонок руководителя или старшего менеджера. Спецусловия: скидка, отсрочка, выезд.'},
  'Hibernating':{ic:'😴',col:'#56709a',
    desc:'Мало, нерегулярно, давно',
    scores:'R≤2 F≤2',
    full:'Небольшие покупки, нерегулярно, давно. Низкий приоритет без стимуляции.',
    action:'Дешёвая рассылка с предложением, опрос о потребностях. Мало ресурсов.'},
  'Promising':{ic:'🚀',col:'#fb923c',
    desc:'Недавние, но ещё редко',
    scores:'R≥3 F≤2 M≤2',
    full:'Покупали недавно, но пока мало раз. Есть интерес — нужно развить.',
    action:'Познакомьте с ассортиментом, предложите демо или тест новых категорий.'},
  'Need Attn':{ic:'👀',col:'#f59e0b',
    desc:'Средние по всем метрикам',
    scores:'R~3 F~2-3',
    full:'Средние показатели по всем трём метрикам. Без внимания скатятся в Hibernating.',
    action:'Регулярный контакт раз в месяц, персональное предложение под сезон.'},
  'Lost':{ic:'💀',col:'#374151',
    desc:'Минимальная активность',
    scores:'R=1 F=1 M=1',
    full:'Очень давно не покупали, мало и мало денег. Скорее всего ушли к конкурентам.',
    action:'Win-back акция в рассылке. Не тратьте дорогие ресурсы — приоритет минимальный.'},
};
function getRFMRows(){
  const n=DATA.length; if(!n)return[];
  // R score: rank by recency (14-rec; smaller=better→higher score)
  const byR=[...DATA].map((r,i)=>({i,v:14-r.rec})).sort((a,b)=>b.v-a.v);
  const rMap=new Map(); byR.forEach((x,rank)=>rMap.set(x.i,Math.ceil((rank+1)/n*5)));
  // F score: months with purchases
  const byF=[...DATA].map((r,i)=>({i,v:r.mo.filter(x=>x>0).length})).sort((a,b)=>b.v-a.v);
  const fMap=new Map(); byF.forEach((x,rank)=>fMap.set(x.i,Math.ceil((rank+1)/n*5)));
  // M score: total revenue
  const byM=[...DATA].map((r,i)=>({i,v:r.total})).sort((a,b)=>b.v-a.v);
  const mMap=new Map(); byM.forEach((x,rank)=>mMap.set(x.i,Math.ceil((rank+1)/n*5)));
  return DATA.map((r,i)=>{
    const rs=rMap.get(i)||1,fs=fMap.get(i)||1,ms=mMap.get(i)||1;
    const seg=rfmSegName(rs,fs,ms);
    return Object.assign({},r,{rs,fs,ms,rfmSeg:seg});
  });
}
function rfmSegName(r,f,m){
  if(r>=4&&f>=4&&m>=4)return'Champions';
  if(r>=3&&f>=3&&m>=4)return'Loyal';
  if(r>=4&&f<=2&&m>=2)return'Pot. Loyalist';
  if(r>=4&&f<=1)return'New Customer';
  if(r<=2&&f>=4&&m>=4)return'Cant Lose';
  if(r<=2&&f>=3&&m>=3)return'At Risk';
  if(r>=3&&f<=2&&m<=2)return'Promising';
  if(r<=2&&f<=2&&m<=2)return'Lost';
  if(r<=2&&f<=2)return'Hibernating';
  return'Need Attn';
}
function renderRFM(m){
  const rows=getRFMRows();
  const segMap={};
  Object.keys(RFM_SEG_META).forEach(s=>segMap[s]={cnt:0,rev:0,rows:[]});
  rows.forEach(r=>{if(segMap[r.rfmSeg]){segMap[r.rfmSeg].cnt++;segMap[r.rfmSeg].rev+=r.total;segMap[r.rfmSeg].rows.push(r);}});
  const segs=Object.keys(RFM_SEG_META);
  const segOrder=segs.slice().sort((a,b)=>(segMap[b]||{rev:0}).rev-(segMap[a]||{rev:0}).rev);
  function resolveCol(col){return col.startsWith('#')?col:'#4f8ef7';}
  m.innerHTML='<div class="pg">'
    +'<div class="pg-hd"><div class="pg-ti">RFM-анализ</div><div class="pg-su">Recency · Frequency · Monetary — '+rows.length+' клиентов</div></div>'
    +'<div class="info-card"><div class="info-label">📌 Что такое RFM и зачем он нужен</div><div class="info-body">'
    +'<strong>RFM-анализ</strong> сегментирует клиентскую базу по трём измерениям: '
    +'<span class="tag">R = Recency</span> — как давно клиент покупал (балл 1–5, 5 = недавно), '
    +'<span class="tag">F = Frequency</span> — как часто покупает (5 = очень часто), '
    +'<span class="tag">M = Monetary</span> — сколько денег приносит (5 = топ-20% по выручке). '
    +'Каждый клиент получает три балла → попадает в один из 10 сегментов. '
    +'<strong>Результат:</strong> понятно кому звонить сейчас, кого реактивировать, кого не трогать. '
    +'Снижает затраты на работу с базой на 20–40%.'
    +'</div></div>'
    +'<div class="rfm-info-grid">'
    +'<div class="rfm-info-card"><div class="rfm-info-letter" style="color:var(--acc)">R</div><b style="font-size:12px">Recency — давность</b><div class="rfm-info-desc" style="margin-top:4px">Кол-во месяцев с последней покупки. Чем меньше — тем выше балл (1–5).</div></div>'
    +'<div class="rfm-info-card"><div class="rfm-info-letter" style="color:var(--cy)">F</div><b style="font-size:12px">Frequency — частота</b><div class="rfm-info-desc" style="margin-top:4px">Кол-во месяцев с покупками за 15 мес. Больше = выше балл.</div></div>'
    +'<div class="rfm-info-card"><div class="rfm-info-letter" style="color:var(--gr)">M</div><b style="font-size:12px">Monetary — деньги</b><div class="rfm-info-desc" style="margin-top:4px">Суммарная выручка за период. Квинтильное ранжирование 1–5.</div></div>'
    +'</div>'
    +'<div class="rfm-seg-grid">'
    +segs.map(s=>{const d=segMap[s];const meta=RFM_SEG_META[s];return '<div class="rfm-seg"><div class="rfm-seg-ic">'+meta.ic+'</div><div class="rfm-seg-name" style="color:'+meta.col+'">'+s+'</div><div class="rfm-seg-cnt">'+d.cnt+'</div><div class="rfm-seg-rev">'+(d.rev?fmt(d.rev):'—')+'</div></div>';}).join('')
    +'</div>'
    +'<div class="info-grid-3">'
    +segs.map(function(s2){var d=segMap[s2];var meta=RFM_SEG_META[s2];return '<div class="info-mini" style="border-left:3px solid '+meta.col+'">'
      +'<div class="info-mini-h">'
      +'<span>'+meta.ic+' <span style="color:'+meta.col+'">'+s2+'</span></span>'
      +'<span style="font-family:var(--fm);font-size:10px;color:var(--mt)">'+meta.scores+'</span>'
      +'</div>'
      +'<div class="info-mini-b">'
      +'<span style="font-size:10px;font-weight:600;color:var(--tx)">'+meta.full+'</span><br>'
      +'<span style="color:var(--acc);font-size:10px">→ </span>'+meta.action
      +'</div></div>';}).join('')
    +'</div>'
    +'<div class="cg22" style="margin-bottom:14px">'
    +'<div class="cc"><div class="cc-ti">Клиентов по сегментам</div><div class="ch-wrap" style="height:230px"><canvas id="ch-rfm-bar"></canvas></div></div>'
    +'<div class="cc"><div class="cc-ti">Доля выручки по сегментам</div><div class="ch-wrap" style="height:230px"><canvas id="ch-rfm-pie"></canvas></div></div>'
    +'</div>'
    +'<div class="tw"><div class="tf">'
    +'<select id="rfm-seg-sel"><option value="">Все сегменты</option>'+segs.map(s=>'<option value="'+s+'">'+RFM_SEG_META[s].ic+' '+s+' ('+segMap[s].cnt+')</option>').join('')+'</select>'
    +'<input id="rfm-srch" placeholder="🔍 Поиск по клиенту..." style="min-width:180px">'
    +'</div><div id="rfm-table" style="overflow-x:auto"></div></div>'
    +'</div>';
  const cols=segOrder.map(s=>resolveCol(RFM_SEG_META[s].col));
  const sc={x:{ticks:{color:'#56709a',font:{size:9}},grid:{color:'rgba(255,255,255,.04)'},border:{display:false}},y:{ticks:{color:'#56709a',font:{size:9}},grid:{color:'rgba(255,255,255,.04)'},border:{display:false}}};
  CHARTS.rfmBar=new Chart(document.getElementById('ch-rfm-bar'),{type:'bar',data:{labels:segOrder,datasets:[{data:segOrder.map(s=>segMap[s].cnt),backgroundColor:cols,borderRadius:4}]},options:{maintainAspectRatio:false,plugins:{...CHART_DEF.plugins,legend:{display:false}},scales:sc}});
  const pieSegs=segs.filter(s=>segMap[s].rev>0);
  CHARTS.rfmPie=new Chart(document.getElementById('ch-rfm-pie'),{type:'doughnut',data:{labels:pieSegs,datasets:[{data:pieSegs.map(s=>segMap[s].rev),backgroundColor:pieSegs.map(s=>resolveCol(RFM_SEG_META[s].col)),borderWidth:1,borderColor:'#111d2e'}]},options:{maintainAspectRatio:false,plugins:{...CHART_DEF.plugins,legend:{labels:{color:'#7a90aa',font:{size:10},boxWidth:12}}}}});
  function drawRFMTable(){
    const seg=document.getElementById('rfm-seg-sel').value;
    const srch=document.getElementById('rfm-srch').value.toLowerCase();
    let list=seg?segMap[seg].rows:rows;
    if(srch)list=list.filter(r=>r.name.toLowerCase().includes(srch));
    const tw=document.getElementById('rfm-table');
    if(!list.length){tw.innerHTML='<div class="no-data">Нет клиентов</div>';return;}
    tw.innerHTML='<table><thead><tr><th>#</th><th>Клиент</th><th>Менеджер</th><th>Сегмент</th><th>RFM баллы</th><th>Выручка</th><th>Частота</th><th>Давность</th></tr></thead><tbody>'
      +list.slice(0,100).map(function(r,i){
        const meta=RFM_SEG_META[r.rfmSeg]||{ic:'?',col:'var(--mt)'};
        const score='<span class="rfm-sc" style="color:'+(r.rs>=4?'#10b981':r.rs>=3?'#f59e0b':'#56709a')+'">R'+r.rs+'</span>'
          +'<span class="rfm-sc" style="margin-left:2px;color:'+(r.fs>=4?'#22d3ee':r.fs>=3?'#4f8ef7':'#56709a')+'">F'+r.fs+'</span>'
          +'<span class="rfm-sc" style="margin-left:2px;color:'+(r.ms>=4?'#10b981':r.ms>=3?'#f59e0b':'#56709a')+'">M'+r.ms+'</span>';
        const freq=r.mo.filter(function(v){return v>0;}).length;
        return '<tr style="cursor:pointer" data-rfmi="'+i+'">'
          +'<td class="td-mono" style="color:var(--mt)">'+(i+1)+'</td>'
          +'<td class="td-name" title="'+esc(r.name)+'">'+esc(r.name)+'</td>'
          +'<td class="td-mgr">'+esc(r.mgr)+'</td>'
          +'<td><span style="color:'+meta.col+'">'+meta.ic+' '+r.rfmSeg+'</span></td>'
          +'<td>'+score+'</td>'
          +'<td class="td-mono">'+fmt(r.total)+'</td>'
          +'<td class="td-mono">'+freq+' мес.</td>'
          +'<td class="td-mono">'+(r.rec>=0?MONTHS[r.rec]:'—')+'</td>'
          +'</tr>';
      }).join('')+'</tbody></table>';
    tw.querySelectorAll('tbody tr').forEach(function(tr,i){tr.addEventListener('click',function(){showClientModal(list[i]);});});
  }
  document.getElementById('rfm-seg-sel').addEventListener('change',drawRFMTable);
  document.getElementById('rfm-srch').addEventListener('input',drawRFMTable);
  drawRFMTable();
}

// ═══════════════════════════════════════════════════════════════════════════
// ─── ABC / XYZ ANALYSIS ───────────────────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════════════
function getABCXYZRows(){
  const sorted=[...DATA].sort(function(a,b){return b.total-a.total;});
  const totAll=sorted.reduce(function(s,r){return s+r.total;},0);
  const abcMap=new Map();
  let cum=0;
  sorted.forEach(function(r){
    cum+=r.total;
    const p=cum/totAll;
    abcMap.set(r.name+'|'+r.mgr, p<=0.8?'A':p<=0.95?'B':'C');
  });
  const xyzMap=new Map();
  DATA.forEach(function(r){
    const vals=r.mo.filter(function(v){return v>0;});
    if(vals.length<2){xyzMap.set(r.name+'|'+r.mgr,'Z');return;}
    const mean=vals.reduce(function(s,v){return s+v;},0)/vals.length;
    const std=Math.sqrt(vals.reduce(function(s,v){return s+(v-mean)*(v-mean);},0)/vals.length);
    const cv=mean>0?std/mean:1;
    xyzMap.set(r.name+'|'+r.mgr,cv<=0.25?'X':cv<=0.5?'Y':'Z');
  });
  return DATA.map(function(r){
    const k=r.name+'|'+r.mgr;
    const a=abcMap.get(k)||'C', x=xyzMap.get(k)||'Z';
    return Object.assign({},r,{abc:a,xyz:x,abcxyz:a+x});
  });
}
const ABC_MAT_DESC={
  AX:'Приоритет: высокая выручка, стабильно',
  AY:'Высокая выручка, умеренная нестабильность',
  AZ:'Высокая выручка, но хаотичный спрос — риск',
  BX:'Стабильные средние — надёжная база',
  BY:'Средние, умеренная нестабильность',
  BZ:'Средние по выручке, непредсказуемые',
  CX:'Мелкие, но предсказуемые',
  CY:'Мелкие и умеренно нестабильные',
  CZ:'Аутсайдеры: мало и хаотично',
};
function renderABCXYZ(m){
  const rows=getABCXYZRows();
  const matrix={};
  ['A','B','C'].forEach(function(a){['X','Y','Z'].forEach(function(x){matrix[a+x]={cnt:0,rev:0,rows:[]};});});
  rows.forEach(function(r){const k=r.abc+r.xyz;matrix[k].cnt++;matrix[k].rev+=r.total;matrix[k].rows.push(r);});
  const totAll=rows.reduce(function(s,r){return s+r.total;},0);
  const cntA=rows.filter(function(r){return r.abc==='A';}).length;
  const cntB=rows.filter(function(r){return r.abc==='B';}).length;
  const cntC=rows.filter(function(r){return r.abc==='C';}).length;
  const cntX=rows.filter(function(r){return r.xyz==='X';}).length;
  const cntY=rows.filter(function(r){return r.xyz==='Y';}).length;
  const cntZ=rows.filter(function(r){return r.xyz==='Z';}).length;
  const abcCols={'A':'rgba(16,185,129,.7)','B':'rgba(245,158,11,.7)','C':'rgba(86,112,154,.6)'};
  const xyzCols={'X':'rgba(79,142,247,.7)','Y':'rgba(139,92,246,.7)','Z':'rgba(244,63,94,.7)'};
  const matBg={'AX':'rgba(16,185,129,.14)','AZ':'rgba(244,63,94,.10)','CZ':'rgba(86,112,154,.08)'};
  m.innerHTML='<div class="pg">'
    +'<div class="pg-hd"><div class="pg-ti">ABC / XYZ анализ</div><div class="pg-su">Классификация по вкладу в выручку и стабильности спроса</div></div>'
    +'<div class="info-card"><div class="info-label">📌 Метод расчёта и применение</div><div class="info-body">'
    +'<strong>ABC</strong> по принципу Парето: <span class="tag">A = топ 80% выручки</span> <span class="tag">B = следующие 15%</span> <span class="tag">C = оставшиеся 5%</span>. '
    +'<strong>XYZ</strong> по коэффициенту вариации CV=σ/μ: <span class="tag">X: CV≤25% — стабильные</span> <span class="tag">Y: CV≤50% — переменные</span> <span class="tag">Z: CV>50% — хаотичные</span>. '
    +'Комбинация даёт матрицу <strong>3×3 = 9 сегментов</strong>. AX = приоритет менеджера, CZ = минимум усилий. '
    +'<strong>Влияние:</strong> оптимизирует распределение времени менеджеров и страховые запасы.'
    +'</div></div>'
    +'<div class="cg22" style="margin-bottom:14px">'
    +'<div class="cc"><div class="cc-ti">ABC — доля в выручке</div>'
    +'<div style="display:flex;gap:6px;margin-bottom:10px">'
    +[['A','#10b981','Топ 80% выручки',cntA],['B','#f59e0b','след. 15%',cntB],['C','#56709a','остальные',cntC]].map(function(x){return '<div style="flex:1;background:var(--s3);border-radius:8px;padding:10px;text-align:center"><div style="font-family:var(--fm);font-size:20px;font-weight:700;color:'+x[1]+'">'+x[0]+'</div><div style="font-size:18px;color:var(--wh);font-family:var(--fm)">'+x[3]+'</div><div style="font-size:10px;color:var(--mt);margin-top:2px">'+x[2]+'</div></div>';}).join('')
    +'</div><div class="ch-wrap" style="height:130px"><canvas id="ch-abc"></canvas></div></div>'
    +'<div class="cc"><div class="cc-ti">XYZ — стабильность (CV)</div>'
    +'<div style="display:flex;gap:6px;margin-bottom:10px">'
    +[['X','#4f8ef7','CV ≤25% стабильный',cntX],['Y','#8b5cf6','CV ≤50% переменный',cntY],['Z','#f43f5e','CV >50% хаотичный',cntZ]].map(function(x){return '<div style="flex:1;background:var(--s3);border-radius:8px;padding:10px;text-align:center"><div style="font-family:var(--fm);font-size:20px;font-weight:700;color:'+x[1]+'">'+x[0]+'</div><div style="font-size:18px;color:var(--wh);font-family:var(--fm)">'+x[3]+'</div><div style="font-size:10px;color:var(--mt);margin-top:2px">'+x[2]+'</div></div>';}).join('')
    +'</div><div class="ch-wrap" style="height:130px"><canvas id="ch-xyz"></canvas></div></div>'
    +'</div>'
    +'<div class="cc" style="margin-bottom:14px"><div class="cc-ti">Матрица ABC × XYZ <span style="color:var(--acc)">· клик по ячейке → список клиентов</span></div>'
    +'<div class="abc-matrix-wrap"><table class="abc-matrix"><thead><tr><td></td>'
    +['X — стабильный','Y — переменный','Z — хаотичный'].map(function(h){return '<th style="font-size:10px;color:var(--mt);padding:0 0 6px;text-align:center">'+h+'</th>';}).join('')
    +'</tr></thead><tbody>'
    +['A','B','C'].map(function(a){
      return '<tr><td style="font-size:10px;color:var(--mt);padding-right:8px;vertical-align:middle;white-space:nowrap">'+a+' — '+(a==='A'?'высокий':a==='B'?'средний':'низкий')+'</td>'
        +['X','Y','Z'].map(function(x){
          const k=a+x; const d=matrix[k];
          const bg=matBg[k]||'rgba(255,255,255,.03)';
          return '<td><div class="abc-cell" style="background:'+bg+'" data-mx="'+k+'">'
            +'<div class="abc-cell-code"><span class="abadge ba'+a.toLowerCase()+' b'+a.toLowerCase()+'">'+a+'</span> <span class="abadge bx by bz b'+x.toLowerCase()+' x'+x.toLowerCase()+'">'+x+'</span></div>'
            +'<div class="abc-cell-cnt">'+d.cnt+' клиентов</div>'
            +'<div class="abc-cell-rev" style="color:var(--tx2)">'+fmt(d.rev)+'</div>'
            +'<div class="abc-cell-desc">'+(ABC_MAT_DESC[k]||'')+'</div>'
            +'</div></td>';
        }).join('')+'</tr>';
    }).join('')
    +'</tbody></table></div></div>'
    +'<div class="tw"><div class="tf">'
    +'<select id="abc-filter"><option value="">Все категории</option>'+['AX','AY','AZ','BX','BY','BZ','CX','CY','CZ'].map(function(k){return '<option value="'+k+'">'+k+' ('+matrix[k].cnt+')</option>';}).join('')+'</select>'
    +'<input id="abc-srch" placeholder="🔍 Поиск..." style="min-width:180px">'
    +'</div><div id="abc-table" style="overflow-x:auto"></div></div>'
    +'</div>';
  const sc={x:{ticks:{color:'#56709a',font:{size:9}},grid:{color:'rgba(255,255,255,.04)'},border:{display:false}},y:{ticks:{color:'#56709a',font:{size:9}},grid:{color:'rgba(255,255,255,.04)'},border:{display:false}}};
  CHARTS.abcCh=new Chart(document.getElementById('ch-abc'),{type:'bar',data:{labels:['A','B','C'],datasets:[{data:[rows.filter(function(r){return r.abc==='A';}).reduce(function(s,r){return s+r.total;},0),rows.filter(function(r){return r.abc==='B';}).reduce(function(s,r){return s+r.total;},0),rows.filter(function(r){return r.abc==='C';}).reduce(function(s,r){return s+r.total;},0)].map(function(v){return Math.round(v/1000);}),backgroundColor:['rgba(16,185,129,.7)','rgba(245,158,11,.7)','rgba(86,112,154,.6)'],borderRadius:5}]},options:{maintainAspectRatio:false,plugins:{...CHART_DEF.plugins,legend:{display:false}},scales:sc}});
  CHARTS.xyzCh=new Chart(document.getElementById('ch-xyz'),{type:'bar',data:{labels:['X','Y','Z'],datasets:[{data:[cntX,cntY,cntZ],backgroundColor:['rgba(79,142,247,.7)','rgba(139,92,246,.7)','rgba(244,63,94,.7)'],borderRadius:5}]},options:{maintainAspectRatio:false,plugins:{...CHART_DEF.plugins,legend:{display:false}},scales:sc}});
  function drawABCTable(cat){
    const srch=(document.getElementById('abc-srch')||{value:''}).value.toLowerCase();
    let list=cat?matrix[cat].rows:rows.slice();
    if(srch)list=list.filter(function(r){return r.name.toLowerCase().includes(srch);});
    list=list.slice().sort(function(a,b){return b.total-a.total;});
    const tw=document.getElementById('abc-table');
    if(!list.length){tw.innerHTML='<div class="no-data">Нет клиентов</div>';return;}
    tw.innerHTML='<table><thead><tr><th>#</th><th>Клиент</th><th>Менеджер</th><th>ABC</th><th>XYZ</th><th>Выручка</th><th>Доля</th><th>Частота</th></tr></thead><tbody>'
      +list.slice(0,80).map(function(r,i){
        return '<tr style="cursor:pointer" data-abci="'+i+'">'
          +'<td class="td-mono" style="color:var(--mt)">'+(i+1)+'</td>'
          +'<td class="td-name" title="'+esc(r.name)+'">'+esc(r.name)+'</td>'
          +'<td class="td-mgr">'+esc(r.mgr)+'</td>'
          +'<td><span class="abadge b'+r.abc.toLowerCase()+'">'+r.abc+'</span></td>'
          +'<td><span class="abadge b'+r.xyz.toLowerCase()+'">'+r.xyz+'</span></td>'
          +'<td class="td-mono">'+fmt(r.total)+'</td>'
          +'<td class="td-mono" style="color:var(--mt)">'+(r.total/totAll*100).toFixed(1)+'%</td>'
          +'<td class="td-mono">'+r.mo.filter(function(v){return v>0;}).length+' мес.</td>'
          +'</tr>';
      }).join('')+'</tbody></table>';
    tw.querySelectorAll('tbody tr').forEach(function(tr,i){tr.addEventListener('click',function(){showClientModal(list[i]);});});
  }
  m.querySelectorAll('[data-mx]').forEach(function(cell){cell.addEventListener('click',function(){
    const k=cell.dataset.mx;
    document.getElementById('abc-filter').value=k;
    drawABCTable(k);
    cell.closest('.cc').scrollIntoView({behavior:'smooth',block:'nearest'});
  });});
  document.getElementById('abc-filter').addEventListener('change',function(e){drawABCTable(e.target.value);});
  document.getElementById('abc-srch').addEventListener('input',function(){drawABCTable(document.getElementById('abc-filter').value);});
  drawABCTable('');
}

// ═══════════════════════════════════════════════════════════════════════════
// ─── LTV ANALYSIS ─────────────────────────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════════════
function getLTVRows(){
  return DATA.map(function(r){
    const activeMo=r.mo.filter(function(v){return v>0;}).length;
    const avgMonthly=activeMo>0?r.total/activeMo:0;
    const retentionRate=activeMo/15;
    const churnRate=Math.max(0.05,1-retentionRate);
    const lifespan=Math.round(1/churnRate);
    const ltv=Math.round(avgMonthly*lifespan);
    const ltv_m=Math.round(ltv*0.25);
    return Object.assign({},r,{activeMo,avgMonthly,retentionRate,lifespan,ltv,ltv_m});
  }).sort(function(a,b){return b.ltv-a.ltv;});
}
function renderLTV(m){
  const rows=getLTVRows();
  const mgrs=[...new Set(DATA.map(function(r){return r.mgr;}))].sort();
  const avgLTV=Math.round(rows.reduce(function(s,r){return s+r.ltv;},0)/rows.length)||0;
  const totalLTV=rows.reduce(function(s,r){return s+r.ltv;},0)||1;
  const top20=rows.slice(0,Math.ceil(rows.length*0.2));
  const top20ltv=top20.reduce(function(s,r){return s+r.ltv;},0);
  const tierH=rows.filter(function(r){return r.ltv>avgLTV*2;}).length;
  const avgLife=Math.round(rows.reduce(function(s,r){return s+r.lifespan;},0)/rows.length)||0;
  m.innerHTML='<div class="pg">'
    +'<div class="pg-hd"><div class="pg-ti">LTV — Lifetime Value</div><div class="pg-su">Прогноз пожизненной ценности клиента</div></div>'
    +'<div class="info-card"><div class="info-label">📌 Формула и применение</div><div class="info-body">'
    +'<strong>LTV</strong> = прогнозная сумма выручки от клиента за всё время. '
    +'Расчёт: <span class="tag">LTV = Avg_месячная_выручка × (1 / Churn_Rate)</span> '
    +'где Churn = 1 − (активных_мес / всего_мес). '
    +'Маржинальный LTV = LTV × 25% (условная маржа). '
    +'<strong>Зачем:</strong> показывает реальную ценность клиента в долгосрочной перспективе. '
    +'Клиент с маленьким разовым заказом, но высокой частотой, может быть ценнее крупного разового.'
    +'</div></div>'
    +'<div class="ltv-formula">Формула: <strong>LTV = AvgMonthly × (1 / ChurnRate)</strong>. Churn = 1 − (активных мес. / 15). Маржинальный LTV = LTV × <strong>25%</strong>. Значения прогнозные.</div>'
    +'<div class="kgrid">'
    +'<div class="kcard kb"><div class="kcard-ic">💎</div><div class="kl">Средний LTV</div><div class="kv">'+fmt(avgLTV)+'</div><div class="kt fl">по базе</div></div>'
    +'<div class="kcard kg"><div class="kcard-ic">🏆</div><div class="kl">Топ-20% = доля LTV</div><div class="kv">'+Math.round(top20ltv/totalLTV*100)+'%</div><div class="kt up">концентрация</div></div>'
    +'<div class="kcard kr"><div class="kcard-ic">📈</div><div class="kl">Высокий LTV (2×avg+)</div><div class="kv">'+tierH+'</div><div class="kt up">приоритет</div></div>'
    +'<div class="kcard kc"><div class="kcard-ic">⏱</div><div class="kl">Средний срок жизни</div><div class="kv">'+avgLife+' мес.</div><div class="kt fl">в среднем</div></div>'
    +'</div>'
    +'<div class="cg22" style="margin-bottom:14px">'
    +'<div class="cc"><div class="cc-ti">Топ-15 клиентов по LTV</div><div class="ch-wrap" style="height:240px"><canvas id="ch-ltv-top"></canvas></div></div>'
    +'<div class="cc"><div class="cc-ti">Средний LTV по менеджерам</div><div class="ch-wrap" style="height:240px"><canvas id="ch-ltv-mgr"></canvas></div></div>'
    +'</div>'
    +'<div class="tw"><div class="tf">'
    +'<select id="ltv-mgr"><option value="">Все менеджеры</option>'+mgrs.map(function(x){return '<option value="'+esc(x)+'">'+esc(x)+'</option>';}).join('')+'</select>'
    +'<select id="ltv-tier"><option value="">Все тиры</option><option value="high">🔴 Высокий (2×avg+)</option><option value="mid">🟡 Средний</option><option value="low">🟢 Ниже среднего</option></select>'
    +'<input id="ltv-srch" placeholder="🔍 Поиск..." style="min-width:160px">'
    +'</div><div id="ltv-table" style="overflow-x:auto"></div></div>'
    +'</div>';
  const sc={x:{ticks:{color:'#56709a',font:{size:8}},grid:{color:'rgba(255,255,255,.04)'},border:{display:false}},y:{ticks:{color:'#56709a',font:{size:9},callback:function(v){return fmt(v);}},grid:{color:'rgba(255,255,255,.04)'},border:{display:false}}};
  const top15=rows.slice(0,15);
  CHARTS.ltvTop=new Chart(document.getElementById('ch-ltv-top'),{type:'bar',data:{labels:top15.map(function(r){return r.name.split(' ').slice(0,2).join(' ');}),datasets:[{label:'LTV',data:top15.map(function(r){return r.ltv;}),backgroundColor:'rgba(139,92,246,.7)',borderRadius:4},{label:'LTV (маржа)',data:top15.map(function(r){return r.ltv_m;}),backgroundColor:'rgba(79,142,247,.5)',borderRadius:4}]},options:{maintainAspectRatio:false,plugins:{...CHART_DEF.plugins},scales:sc}});
  const mgrLTV={};
  rows.forEach(function(r){if(!mgrLTV[r.mgr]){mgrLTV[r.mgr]={sum:0,cnt:0};}mgrLTV[r.mgr].sum+=r.ltv;mgrLTV[r.mgr].cnt++;});
  const mgrArr=Object.entries(mgrLTV).map(function(e){return{name:e[0].split(' ').slice(0,2).join(' '),avg:Math.round(e[1].sum/e[1].cnt)};}).sort(function(a,b){return b.avg-a.avg;}).slice(0,8);
  CHARTS.ltvMgr=new Chart(document.getElementById('ch-ltv-mgr'),{type:'bar',data:{labels:mgrArr.map(function(x){return x.name;}),datasets:[{label:'Средний LTV',data:mgrArr.map(function(x){return x.avg;}),backgroundColor:PC.slice(0,8),borderRadius:4}]},options:{maintainAspectRatio:false,plugins:{...CHART_DEF.plugins,legend:{display:false}},scales:{x:{ticks:{color:'#56709a',font:{size:8}},grid:{color:'rgba(255,255,255,.04)'},border:{display:false}},y:{ticks:{color:'#56709a',font:{size:9},callback:function(v){return fmt(v);}},grid:{color:'rgba(255,255,255,.04)'},border:{display:false}}}}});
  function drawLTVTable(){
    const mgr=document.getElementById('ltv-mgr').value;
    const tier=document.getElementById('ltv-tier').value;
    const srch=document.getElementById('ltv-srch').value.toLowerCase();
    let list=rows.slice();
    if(mgr)list=list.filter(function(r){return r.mgr===mgr;});
    if(tier==='high')list=list.filter(function(r){return r.ltv>avgLTV*2;});
    else if(tier==='mid')list=list.filter(function(r){return r.ltv>avgLTV&&r.ltv<=avgLTV*2;});
    else if(tier==='low')list=list.filter(function(r){return r.ltv<=avgLTV;});
    if(srch)list=list.filter(function(r){return r.name.toLowerCase().includes(srch);});
    const tw=document.getElementById('ltv-table');
    if(!list.length){tw.innerHTML='<div class="no-data">Нет клиентов</div>';return;}
    tw.innerHTML='<table><thead><tr><th>#</th><th>Клиент</th><th>Менеджер</th><th>LTV</th><th>LTV (маржа)</th><th>Ср.мес.выручка</th><th>Срок жизни</th><th>Удержание</th></tr></thead><tbody>'
      +list.slice(0,80).map(function(r,i){
        const tier2=r.ltv>avgLTV*2?'🔴':r.ltv>avgLTV?'🟡':'🟢';
        const pct2=Math.round(r.retentionRate*100);
        const pbar='<span class="pbar-wrap"><span class="pbar-fill" style="width:'+pct2+'%;background:'+(pct2>=60?'var(--gr)':pct2>=30?'var(--warm)':'var(--hot)')+'"></span></span>'+pct2+'%';
        return '<tr style="cursor:pointer" data-ltvi="'+i+'">'
          +'<td class="td-mono" style="color:var(--mt)">'+(i+1)+'</td>'
          +'<td class="td-name" title="'+esc(r.name)+'">'+esc(r.name)+'</td>'
          +'<td class="td-mgr">'+esc(r.mgr)+'</td>'
          +'<td class="td-mono" style="color:var(--pu);font-weight:600">'+tier2+' '+fmt(r.ltv)+'</td>'
          +'<td class="td-mono" style="color:var(--acc)">'+fmt(r.ltv_m)+'</td>'
          +'<td class="td-mono">'+fmt(Math.round(r.avgMonthly))+'</td>'
          +'<td class="td-mono">'+r.lifespan+' мес.</td>'
          +'<td style="font-size:11px">'+pbar+'</td>'
          +'</tr>';
      }).join('')+'</tbody></table>';
    tw.querySelectorAll('tbody tr').forEach(function(tr,i){tr.addEventListener('click',function(){showClientModal(list[i]);});});
  }
  ['ltv-mgr','ltv-tier'].forEach(function(id){document.getElementById(id).addEventListener('change',drawLTVTable);});
  document.getElementById('ltv-srch').addEventListener('input',drawLTVTable);
  drawLTVTable();
}

// ═══════════════════════════════════════════════════════════════════════════
// ─── COHORT ANALYSIS ──────────────────────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════════════
function renderCohorts(m){
  const cohortMap={};
  DATA.forEach(function(r){
    const firstMo=r.mo.findIndex(function(v){return v>0;});
    if(firstMo<0)return;
    if(!cohortMap[firstMo])cohortMap[firstMo]={label:MONTHS[firstMo],firstMo:firstMo,clients:[]};
    cohortMap[firstMo].clients.push(r);
  });
  const cohorts=Object.values(cohortMap).sort(function(a,b){return a.firstMo-b.firstMo;});
  const maxOff=14;
  const cohortData=cohorts.map(function(c){
    const n=c.clients.length;
    const ret=[];
    for(var off=0;off<=maxOff;off++){
      const moIdx=c.firstMo+off;
      if(moIdx>14){ret.push(null);continue;}
      const active=c.clients.filter(function(r){return(r.mo[moIdx]||0)>0;}).length;
      ret.push(Math.round(active/n*100));
    }
    return{label:c.label,n:n,ret:ret};
  });
  const offLabels=Array.from({length:maxOff+1},function(_,i){return i===0?'M0':'M+'+i;});
  function hcol(v){
    if(v===null)return'transparent';
    if(v===0)return'rgba(255,255,255,.03)';
    if(v>=80)return'#1d4ed8';if(v>=60)return'#2563eb';if(v>=40)return'#3b82f6';
    if(v>=20)return'#60a5fa';if(v>=5)return'#93c5fd';return'#bfdbfe';
  }
  function tcol(v){return(v===null||v===0)?'transparent':'rgba(255,255,255,.85)';}
  const avgRet=offLabels.map(function(_,off){
    const vals=cohortData.map(function(c){return c.ret[off];}).filter(function(v){return v!==null&&v!==undefined;});
    return vals.length?Math.round(vals.reduce(function(s,v){return s+v;},0)/vals.length):null;
  });
  m.innerHTML='<div class="pg">'
    +'<div class="pg-hd"><div class="pg-ti">Когортный анализ</div><div class="pg-su">Retention по месяцам с первой покупки — '+cohorts.length+' когорт</div></div>'
    +'<div class="info-card"><div class="info-label">📌 Как читать и что искать</div><div class="info-body">'
    +'<strong>Когорта</strong> = группа клиентов с одинаковым месяцем первой покупки. '
    +'<span class="tag">M0</span> = базовый месяц (первая покупка). '
    +'<span class="tag">M+1, M+2...</span> = % клиентов когорты, купивших через N месяцев после первой. '
    +'Резкое падение на M+1 → проблема удержания после первой сделки. '
    +'Стабильное плато → сильная лояльность. '
    +'<strong>Влияние:</strong> найдите оптимальный момент для follow-up звонка — это М+1 или М+2.'
    +'</div></div>'
    +'<div class="ai-card" style="margin-bottom:16px"><div class="ai-hd"><span class="ai-hd-ic">📖</span><span class="ai-hd-ti">Как читать матрицу</span></div>'
    +'<div class="ai-body" style="font-size:12px;color:var(--tx2)"><b>M0</b> = месяц первой покупки (базовый). <b>M+1</b> = доля купивших в следующем месяце. Пустые ячейки — нет данных за период. Чем синее — тем выше удержание.</div></div>'
    +'<div class="cc" style="margin-bottom:14px"><div class="cc-ti">Retention matrix <span>'+cohorts.length+' когорт × '+offLabels.length+' периодов</span></div>'
    +'<div class="cohort-wrap"><table class="cohort-table"><thead><tr>'
    +'<th class="cohort-th" style="text-align:left;padding-right:6px">Когорта</th>'
    +'<th class="cohort-th">N</th>'
    +offLabels.map(function(l){return '<th class="cohort-th">'+l+'</th>';}).join('')
    +'</tr></thead><tbody>'
    +cohortData.map(function(c){
      return '<tr><td class="cohort-rn" title="'+c.label+'">'+c.label+'</td>'
        +'<td style="font-family:var(--fm);font-size:10px;color:var(--tx2);padding:0 6px;text-align:center">'+c.n+'</td>'
        +c.ret.map(function(v,i){return '<td><div class="cohort-cell" style="background:'+hcol(v)+';color:'+tcol(v)+'" title="'+c.label+' '+offLabels[i]+': '+(v===null?'нет данных':v+'%')+'">'+( v===null?'':v+'%')+'</div></td>';}).join('')
        +'</tr>';
    }).join('')
    +'</tbody></table></div>'
    +'<div class="hm-legend" style="margin-top:10px"><span>0%</span>'
    +[['#bfdbfe','10%'],['#93c5fd','25%'],['#60a5fa','40%'],['#3b82f6','60%'],['#2563eb','80%'],['#1d4ed8','100%']].map(function(x){return '<span class="hm-lc" style="background:'+x[0]+'"></span><span style="font-size:10px;color:var(--mt)">'+x[1]+'</span>';}).join('')
    +'</div></div>'
    +'<div class="cc"><div class="cc-ti">Средний Retention по месяцам <span>% активных клиентов когорты</span></div>'
    +'<div class="ch-wrap" style="height:200px"><canvas id="ch-cohort-avg"></canvas></div></div>'
    +'</div>';
  CHARTS.cohortAvg=new Chart(document.getElementById('ch-cohort-avg'),{
    type:'line',
    data:{labels:offLabels,datasets:[{label:'Avg Retention %',data:avgRet,borderColor:'#3b82f6',backgroundColor:'rgba(59,130,246,.12)',fill:true,tension:.4,borderWidth:2.5,pointRadius:3,pointBackgroundColor:'#3b82f6',spanGaps:true}]},
    options:{maintainAspectRatio:false,plugins:{...CHART_DEF.plugins,legend:{display:false}},scales:{x:{ticks:{color:'#56709a',font:{size:9}},grid:{color:'rgba(255,255,255,.04)'},border:{display:false}},y:{min:0,max:100,ticks:{color:'#56709a',font:{size:9},callback:function(v){return v+'%';}},grid:{color:'rgba(255,255,255,.04)'},border:{display:false}}}}
  });
}

// ─── INIT ─────────────────────────────────────────────────────────────────
Chart.defaults.color='#7a94bb';
Chart.defaults.borderColor='rgba(255,255,255,.05)';

// ── THEME TOGGLE ──────────────────────────────────────────────────────────
function applyTheme(){
  if(DARK_MODE){
    document.documentElement.classList.remove('light');
    Chart.defaults.color='#7a94bb';
    Chart.defaults.borderColor='rgba(255,255,255,.05)';
    CHART_DEF.plugins.tooltip.backgroundColor='#1a2540';
    CHART_DEF.plugins.tooltip.titleColor='#e8f1fb';
    CHART_DEF.plugins.tooltip.bodyColor='#7a94bb';
    CHART_DEF.plugins.legend.labels.color='#7a94bb';
    CHART_DEF.scales.x.ticks.color='#56709a';
    CHART_DEF.scales.y.ticks.color='#56709a';
    CHART_DEF.scales.x.grid.color='rgba(255,255,255,.04)';
    CHART_DEF.scales.y.grid.color='rgba(255,255,255,.04)';
  } else {
    document.documentElement.classList.add('light');
    Chart.defaults.color='#436078';
    Chart.defaults.borderColor='rgba(30,60,120,.07)';
    CHART_DEF.plugins.tooltip.backgroundColor='#ffffff';
    CHART_DEF.plugins.tooltip.titleColor='#0f172a';
    CHART_DEF.plugins.tooltip.bodyColor='#436078';
    CHART_DEF.plugins.legend.labels.color='#436078';
    CHART_DEF.scales.x.ticks.color='#476080';
    CHART_DEF.scales.y.ticks.color='#476080';
    CHART_DEF.scales.x.grid.color='rgba(30,60,120,.06)';
    CHART_DEF.scales.y.grid.color='rgba(30,60,120,.06)';
  }
  const btn=document.getElementById('theme-btn');
  if(btn)btn.textContent=DARK_MODE?'☀️':'🌙';
}
document.addEventListener('click',function(e){
  if(e.target.id==='theme-btn'){
    DARK_MODE=!DARK_MODE;
    applyTheme();
    if(DATA.length)renderPage();
  }
});

// ── MOBILE OVERFLOW FIX ───────────────────────────────────────────────────
function fixMobileOverflow(){
  const mobile=window.innerWidth<=860;
  document.body.style.overflow=mobile?'auto':'hidden';
  document.documentElement.style.overflow=mobile?'auto':'hidden';
  const app=document.getElementById('app');
  if(app)app.style.height=mobile?'auto':'100vh';
}
window.addEventListener('resize',fixMobileOverflow);
fixMobileOverflow();

buildSidebar();
renderPage();
</script>
</body>
</html>

<!-- ML & AI Settings Modal -->
<div id="settingsModal" class="modal" style="display:none; position:fixed; z-index:1000; left:0; top:0; width:100%; height:100%; background-color:rgba(0,0,0,0.5);">
  <div style="background:#fff; margin:10% auto; padding:20px; border-radius:8px; width:400px; position:relative;">
    <span onclick="closeSettings()" style="position:absolute; right:15px; top:10px; cursor:pointer; font-size:24px;">&times;</span>
    <h2>⚙️ Настройки AI & ML</h2>
    
    <label style="display:block; margin-top:15px;"><b>AI API Endpoint</b> (URL провайдера)</label>
    <input type="text" id="aiEndpoint" placeholder="https://api.openai.com/v1/chat/completions" style="width:100%; padding:8px; margin-top:5px; border:1px solid #ddd; border-radius:4px;">
    <small style="color:#666;">Пример для OpenAI, DeepSeek, LocalAI</small>

    <label style="display:block; margin-top:15px;"><b>AI API Key</b></label>
    <input type="password" id="aiKey" placeholder="sk-..." style="width:100%; padding:8px; margin-top:5px; border:1px solid #ddd; border-radius:4px;">

    <label style="display:block; margin-top:15px;"><b>Model Name</b></label>
    <input type="text" id="aiModel" placeholder="gpt-3.5-turbo" style="width:100%; padding:8px; margin-top:5px; border:1px solid #ddd; border-radius:4px;">

    <button onclick="saveSettings()" style="margin-top:20px; width:100%; padding:10px; background:#27ae60; color:white; border:none; border-radius:4px; cursor:pointer;">Сохранить</button>
  </div>
</div>

<script>
// Функции настроек
function openSettings() {
  document.getElementById('settingsModal').style.display = 'block';
  document.getElementById('aiEndpoint').value = localStorage.getItem('aiEndpoint') || 'https://api.openai.com/v1/chat/completions';
  document.getElementById('aiKey').value = localStorage.getItem('aiKey') || '';
  document.getElementById('aiModel').value = localStorage.getItem('aiModel') || 'gpt-3.5-turbo';
}

function closeSettings() {
  document.getElementById('settingsModal').style.display = 'none';
}

function saveSettings() {
  const endpoint = document.getElementById('aiEndpoint').value;
  const key = document.getElementById('aiKey').value;
  const model = document.getElementById('aiModel').value;
  
  localStorage.setItem('aiEndpoint', endpoint);
  localStorage.setItem('aiKey', key);
  localStorage.setItem('aiModel', model);
  
  alert('Настройки сохранены!');
  closeSettings();
}

// Обновленная функция loadAIInsights с универсальной поддержкой
async function loadAIInsights() {
  const endpoint = localStorage.getItem('aiEndpoint');
  const key = localStorage.getItem('aiKey');
  const model = localStorage.getItem('aiModel');

  if (!key || !endpoint) {
    alert('Пожалуйста, настройте API ключ и эндпоинт в разделе "Настройки" (⚙️).');
    return;
  }

  // Сбор данных для анализа
  const data = window.salesData || [];
  const summary = `Всего клиентов: ${data.length}. Общая выручка: ${data.reduce((s, c) => s + (c.monetary||0), 0)}.`;
  
  const prompt = `Проанализируй данные CRM: ${summary}. Дай 3 кратких совета по увеличению продаж.`;

  try {
    const response = await fetch(endpoint, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${key}`
      },
      body: JSON.stringify({
        model: model,
        messages: [{role: "user", content: prompt}]
      })
    });

    if (!response.ok) throw new Error(`Ошибка API: ${response.status}`);
    
    const result = await response.json();
    const text = result.choices ? result.choices[0].message.content : JSON.stringify(result);
    
    document.getElementById('aiOutput').innerHTML = `<div class="insight-card"><h3>🤖 AI Инсайт</h3><p>${text}</p></div>`;
  } catch (err) {
    document.getElementById('aiOutput').innerHTML = `<div class="error-card">Ошибка: ${err.message}</div>`;
  }
}
</script>

<!-- ML & AI Settings Modal -->
<div id="settingsModal" class="modal" style="display:none; position:fixed; z-index:1000; left:0; top:0; width:100%; height:100%; background-color:rgba(0,0,0,0.5);">
  <div style="background:#fff; margin:10% auto; padding:20px; border-radius:8px; width:400px; position:relative;">
    <span onclick="closeSettings()" style="position:absolute; right:15px; top:10px; cursor:pointer; font-size:24px;">&times;</span>
    <h2>⚙️ Настройки AI & ML</h2>
    
    <label style="display:block; margin-top:15px;"><b>AI API Endpoint</b> (URL провайдера)</label>
    <input type="text" id="aiEndpoint" placeholder="https://api.openai.com/v1/chat/completions" style="width:100%; padding:8px; margin-top:5px; border:1px solid #ddd; border-radius:4px;">
    <small style="color:#666;">Пример для OpenAI, DeepSeek, LocalAI</small>

    <label style="display:block; margin-top:15px;"><b>AI API Key</b></label>
    <input type="password" id="aiKey" placeholder="sk-..." style="width:100%; padding:8px; margin-top:5px; border:1px solid #ddd; border-radius:4px;">

    <label style="display:block; margin-top:15px;"><b>Model Name</b></label>
    <input type="text" id="aiModel" placeholder="gpt-3.5-turbo" style="width:100%; padding:8px; margin-top:5px; border:1px solid #ddd; border-radius:4px;">

    <button onclick="saveSettings()" style="margin-top:20px; width:100%; padding:10px; background:#27ae60; color:white; border:none; border-radius:4px; cursor:pointer;">Сохранить</button>
  </div>
</div>

<script>
// Функции настроек
function openSettings() {
  document.getElementById('settingsModal').style.display = 'block';
  document.getElementById('aiEndpoint').value = localStorage.getItem('aiEndpoint') || 'https://api.openai.com/v1/chat/completions';
  document.getElementById('aiKey').value = localStorage.getItem('aiKey') || '';
  document.getElementById('aiModel').value = localStorage.getItem('aiModel') || 'gpt-3.5-turbo';
}

function closeSettings() {
  document.getElementById('settingsModal').style.display = 'none';
}

function saveSettings() {
  const endpoint = document.getElementById('aiEndpoint').value;
  const key = document.getElementById('aiKey').value;
  const model = document.getElementById('aiModel').value;
  
  localStorage.setItem('aiEndpoint', endpoint);
  localStorage.setItem('aiKey', key);
  localStorage.setItem('aiModel', model);
  
  alert('Настройки сохранены!');
  closeSettings();
}

// Обновленная функция loadAIInsights с универсальной поддержкой
async function loadAIInsights() {
  const endpoint = localStorage.getItem('aiEndpoint');
  const key = localStorage.getItem('aiKey');
  const model = localStorage.getItem('aiModel');

  if (!key || !endpoint) {
    alert('Пожалуйста, настройте API ключ и эндпоинт в разделе "Настройки" (⚙️).');
    return;
  }

  // Сбор данных для анализа
  const data = window.salesData || [];
  const summary = `Всего клиентов: ${data.length}. Общая выручка: ${data.reduce((s, c) => s + (c.monetary||0), 0)}.`;
  
  const prompt = `Проанализируй данные CRM: ${summary}. Дай 3 кратких совета по увеличению продаж.`;

  try {
    const response = await fetch(endpoint, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${key}`
      },
      body: JSON.stringify({
        model: model,
        messages: [{role: "user", content: prompt}]
      })
    });

    if (!response.ok) throw new Error(`Ошибка API: ${response.status}`);
    
    const result = await response.json();
    const text = result.choices ? result.choices[0].message.content : JSON.stringify(result);
    
    document.getElementById('aiOutput').innerHTML = `<div class="insight-card"><h3>🤖 AI Инсайт</h3><p>${text}</p></div>`;
  } catch (err) {
    document.getElementById('aiOutput').innerHTML = `<div class="error-card">Ошибка: ${err.message}</div>`;
